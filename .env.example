# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real secrets.

# The base URL of your Anthropic-compatible local endpoint.
# Claude Code will send all API requests here instead of api.anthropic.com.
# Usually do not include a trailing slash.
# Some gateways, such as Docker Model Runner, may require a path that already contains /v1.
# Use the exact base URL required by your gateway.
#
# Examples:
#   http://localhost:8000          (vLLM)
#   http://localhost:4000          (LiteLLM proxy)
#   http://localhost:12434/engines/llama.cpp/v1   (Docker Model Runner)
ANTHROPIC_BASE_URL=http://localhost:8000

# API key sent with every request.
# Most local servers accept any non-empty string.
# Change this if your server requires a specific token.
ANTHROPIC_API_KEY=dummy

# Optional: override which model name is requested.
# Only needed if your server requires a specific model ID string.
# Leave commented out to use Claude Code's default.
# ANTHROPIC_MODEL=your-model-id-here
